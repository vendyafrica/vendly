{
  "name": "@vendly/api",
  "version": "1.0.0",
  "description": "Vendly backend API server",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env PORT=8000 nodemon --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.{ts,js}",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clerk/express": "^1.7.33",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@vendly/auth": "workspace:*",
    "@vendly/database": "workspace:*",
    "@vendly/transactional": "workspace:*",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "resend": "^6.5.2",
    "v0-sdk": "^0.15.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/supertest": "^6.0.2",
    "better-auth": "^1.3.27",
    "cross-env": "^7.0.3",
    "eslint": "^9.21.0",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "undici-types": "6.21.0"
  }
}