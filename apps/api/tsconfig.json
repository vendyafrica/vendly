{
  "extends": "@vendly/typescript-config/tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "paths": {
      "@vendly/auth": [
        "../../../packages/auth/src/index.ts"
      ],
      "@vendly/auth/*": [
        "../../../packages/auth/src/*"
      ],
      "@vendly/database": [
        "../../../packages/database/src/index.ts"
      ],
      "@vendly/database/*": [
        "../../../packages/database/src/*"
      ],
      "@vendly/transactional": [
        "../../../packages/transactional/src/index.ts"
      ],
      "@vendly/transactional/*": [
        "../../../packages/transactional/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": []
}