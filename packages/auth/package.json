{
  "name": "@vendly/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "better-auth": "^1.1.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "eslint": "^9.21.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3"
  }
}