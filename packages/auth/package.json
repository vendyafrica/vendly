{
  "name": "@vendly/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/client.ts --format esm --dts --watch"
  },
  "dependencies": {
    "better-auth": "^1.1.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "eslint": "^9.21.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}