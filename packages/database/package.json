{
  "name": "@vendly/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
   "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "push": "drizzle-kit push",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.7",
    "postgres": "^3.4.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "drizzle-kit": "^0.20.14",
    "eslint": "^9.21.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  }
}